# ══════════════════════════════════════════════
#  Railway Monitor Bot — Sozlamalar
#  Bu faylni nusxa oling: cp .env.example .env
#  Keyin .env ni tahrirlang
# ══════════════════════════════════════════════

# @BotFather dan olingan token (MAJBURIY)
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Faqat shu Telegram ID ga ruxsat (tavsiya etiladi)
# @userinfobot ga yozing — ID ni bilasiz
# Bir nechta: 123456789,987654321
ALLOWED_USERS=123456789

# Tekshirish oralig'i soniyada (kamida 30)
CHECK_INTERVAL=60

# Bir vaqtda max monitoring soni
MAX_MONITORS_PER_USER=3
